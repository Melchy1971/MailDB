# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=mail
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mailknowledge

# ── App Resources ─────────────────────────────────────────────────────────────
# Backend / Worker connection strings
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0

# Storage
# Development: unused (docker volume)
# Production (Unraid): base path for persistent data
UNRAID_APPDATA=/mnt/user/appdata/mailknowledge

UPLOADS_DIR=/uploads

# AI / LLM
# Use 'host.docker.internal' for Mac/Windows, or the actual IP for Linux/Unraid
OLLAMA_HOST=http://host.docker.internal:11434
EMBEDDING_DIM=768

# ── App Config ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=false
# JSON array — restrict in production: '["https://your-domain.com"]'
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Ports (host-side) ─────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set to the public hostname when running behind a reverse proxy
NEXT_PUBLIC_API_URL=http://localhost:8000
